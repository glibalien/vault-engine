{
  "name": "vault-engine",
  "version": "0.1.0",
  "description": "Database-authoritative knowledge graph engine for markdown vaults",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "start:http": "node dist/index.js --transport http",
    "test:perf": "vitest run tests/perf/ --config vitest.perf.config.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@deepgram/sdk": "^5.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "express": "^5.2.1",
    "mammoth": "^1.12.0",
    "nanoid": "^5.1.7",
    "officeparser": "^6.0.7",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "sqlite-vec": "^0.1.9",
    "typescript": "^6.0.2",
    "unified": "^11.0.5",
    "unpdf": "^1.4.0",
    "vitest": "^4.1.4",
    "xlsx": "^0.18.5",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0"
  }
}
